---
import Layout from "./Layout.astro"
let currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "")

if (currentPath.endsWith("/")) {
    currentPath = currentPath.slice(0, -1)
}

const pathTitle = decodeURIComponent(currentPath.split("/")[1])

// Extract title from frontmatter props or use path-based title as fallback
const title = Astro.props.frontmatter.title || pathTitle
const { url, headings } = Astro.props
---

<Layout title={`${title} • Blue Web`}>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-9 markdown-rendered position-relative">
                <button
                    type="button"
                    class="btn btn-outline-secondary d-md-none mt-3"
                    command="show-modal"
                    commandfor="toc">On this page</button
                >

                <slot />

                <div class="mb-3">
                    <a
                        href={`https://github.com/bruegmann/blue-web/edit/main/site/src/pages/${currentPath}.mdx`}
                        class="link-secondary">Edit post on GitHub</a
                    >
                </div>
            </div>

            <div class="col-md-3">
                <div class="sticky-top pt-4">
                    <dialog class="blue-md-modal blue-modal modal" id="toc" aria-describedby="tocLabel">
                        <div class="offcanvas offcanvas-end show">
                            <div class="offcanvas-header">
                                <h2 class="h5 offcanvas-title" id="tocLabel">On this page</h2>
                                <form method="dialog" style="display: contents;">
                                    <button type="submit" class="btn-close" aria-label="Close"></button>
                                </form>
                            </div>
                            <div class="offcanvas-body">
                                <h2 class="page-header h5 d-none d-md-block">On this page</h2>

                                <nav class="docs-toc">
                                    <ul>
                                        {
                                            headings.map((heading) => (
                                                <li style={`padding-left: ${heading.depth - 1}rem`}>
                                                    <a href={`${url}#${heading.slug}`}>{heading.text}</a>
                                                </li>
                                            ))
                                        }
                                    </ul>
                                </nav>
                            </div>
                        </div>
                        <form method="dialog" class="blue-modal-backdrop"><button>Close</button></form>
                    </dialog>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { init } from "@/src/js/modal-responsive"

    document.addEventListener("DOMContentLoaded", () => {
        const tocEl = document.getElementById("toc")
        if (tocEl) {
            init(tocEl as HTMLDialogElement)
        }
    })
</script>
